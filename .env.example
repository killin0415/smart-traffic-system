# Smart traffic system — example environment variables.
# Copy to `.env` (repo root, gitignored) and fill in real values.
#
# Usage modes:
#   - Local dev (gradle bootRun + uv run python main.py): main.py auto-loads
#     this file; DATABASE_URL / KAFKA_BOOTSTRAP_SERVERS below apply.
#   - Docker compose: run `docker compose -f infra/docker-compose.yml --env-file
#     .env up -d` from repo root. The compose file overrides DATABASE_URL /
#     KAFKA_BOOTSTRAP_SERVERS to the in-network service names, so only the
#     secrets in this file actually matter.

# --- LLM provider (chat agent) ---
# Pick one or both; chat agent prefers DEEPSEEK if both are set.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
GEMINI_API_KEY=

# --- TDX (Transport Data eXchange) — required for live VD ingestion ---
# Get keys at https://tdx.transportdata.tw → MemberCenter → 應用程式管理
# Leave blank to skip live traffic refresh (routing still works on static graph).
TDX_CLIENT_ID=
TDX_CLIENT_SECRET=

# --- DB / infra (LOCAL DEV ONLY; compose overrides these) ---
DATABASE_URL=postgresql+asyncpg://admin:secret@localhost:5432/traffic_data
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# --- Refresh intervals (seconds) ---
VD_REFRESH_SECONDS=300
PARKING_REFRESH_SECONDS=300

# --- A* tuning ---
# Penalty (in seconds) added per traffic_signals node along the path.
SIGNAL_PENALTY_SECONDS=20
